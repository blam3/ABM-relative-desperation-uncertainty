    "## 2. Model code\n",
    "\n",
    "All model logic is self-contained here — no external files needed."
   ],
   "id": "model-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.colors as mcolors\n",
    "import seaborn as sns\n",
    "from scipy.stats import bernoulli, t as t_dist\n",
    "import mesa\n",
    "from mesa import Model, Agent\n",
    "from mesa.space import SingleGrid\n",
    "from mesa.datacollection import DataCollector\n",
    "\n",
    "# ── Cognitive functions ────────────────────────────────────────────────────────\n",
    "\n",
    "def utility_function(wealth, gamma):\n",
    "    \"\"\"Power utility — sign-preserving for negative wealth (debt).\"\"\"\n",
    "    wealth = np.clip(wealth, -1e6, 1e6)\n",
    "    if wealth == 0:\n",
    "        return 0.0\n",
    "    return np.sign(wealth) * (np.abs(wealth) ** gamma)\n",
    "\n",
    "def prelec(beta, alpha, p):\n",
    "    \"\"\"Prelec's probability weighting function.\"\"\"\n",
    "    if p == 0:\n",
    "        return 0\n",
    "    log_p = np.clip(np.log(p), -50, 0)\n",
    "    log_val = np.clip(-beta * ((-log_p) ** alpha), -700, 700)\n",
    "    return np.exp(log_val)\n",
    "\n",
    "def cal_income_rank(i, n):\n",
    "    return (i - 1) / (n - 1)\n",
    "\n",
    "def desperation_utility(lambd, gamma, wealth):\n",
    "    \"\"\"Amplified utility for desperate agents (Relative Deprivation Theory).\"\"\"\n",
    "    return utility_function(wealth, gamma) * (1 + lambd * 0.5)\n",
    "\n",
    "def SV_rule_break(reward_rb, cost_rb, wealth, p, gamma, beta, alpha):\n",
    "    w_p = prelec(beta, alpha, p)\n",
    "    return w_p * utility_function(wealth + reward_rb, gamma) - (1 - w_p) * utility_function(wealth - cost_rb, gamma)\n",
    "\n",
    "def SV_rule_break_desperate(lambd, gamma, wealth, p, beta, alpha, reward_rb, cost_rb):\n",
    "    w_p = prelec(beta, alpha, p)\n",
    "    return w_p * desperation_utility(lambd, gamma, wealth + reward_rb) - (1 - w_p) * desperation_utility(lambd, gamma, wealth - cost_rb)\n",
    "\n",
    "def SV_follow_rules(reward_rf, wealth, gamma):\n",
    "    return utility_function(wealth + reward_rf, gamma)\n",
    "\n",
    "def bounded_softmax(SV_rb, SV_rf, tau=3, theta=1.5):\n",
    "    \"\"\"Probabilistic bounded-rational choice. tau = satisficing threshold, theta = noise.\"\"\"\n",
    "    delta = np.clip((SV_rb - SV_rf - tau) / theta, -500, 500)\n",
    "    p_rb = 1 / (1 + np.exp(-delta))\n",
    "    return p_rb\n",
    "\n",
    "# ── Agent ─────────────────────────────────────────────────────────────────────\n",
    "\n",
    "class Individual(Agent):\n",
    "    def __init__(self, model, lambd, gamma, reward_rb, reward_rf, cost_rb,\n",
    "                 min_start_wealth, p, beta_loc, beta_scale, alpha_loc, alpha_scale,\n",
    "                 num_neighbors, income_rank_threshold):\n",
    "        super().__init__(model)\n",
    "        self.lambd = lambd\n",
    "        self.gamma = gamma\n",
    "        self.reward_rb = reward_rb\n",
    "        self.reward_rf = reward_rf\n",
    "        self.cost_rb = cost_rb\n",
    "        self.p = p\n",
    "        self.num_neighbors = num_neighbors\n",
    "        self.income_rank_threshold = income_rank_threshold\n",
    "\n",
    "        n_agents = model.width * model.height\n",
    "        df = max(10, n_agents - 1)\n",
    "        self.beta = np.clip(t_dist.rvs(df=df, loc=beta_loc, scale=beta_scale), -10, 10)\n",
    "        self.alpha = np.clip(t_dist.rvs(df=df, loc=alpha_loc, scale=alpha_scale), 0.1, 10)\n",
    "        self.wealth = np.clip(\n",
    "            np.random.pareto(a=3) * 200 + min_start_wealth,\n",
    "            min_start_wealth, min_start_wealth * 100\n",
    "        )\n",
    "        self.income_rank = 0\n",
    "        self.desperate_state = 0\n",
    "        self.decision = 0\n",
    "        self.caught = False\n",
    "\n",
    "    def relative_desperation(self):\n",
    "        neighbors = self.model.grid.get_neighbors(self.pos, moore=True,\n",
    "                                                   include_center=False,\n",
    "                                                   radius=self.num_neighbors)\n",
    "        neighbor_wealths = [n.wealth for n in neighbors]\n",
    "        num_poorer = sum(1 for w in neighbor_wealths if w <= self.wealth)\n",
    "        n = len(neighbor_wealths)\n",
    "        self.income_rank = cal_income_rank(num_poorer + 1, n + 1) if n > 0 else 0\n",
    "        self.desperate_state = 1 if self.income_rank <= self.income_rank_threshold else 0\n",
    "\n",
    "    def compute_decision(self):\n",
    "        if self.desperate_state == 1:\n",
    "            sv_rb = SV_rule_break_desperate(\n",
    "                lambd=self.lambd, gamma=self.gamma, wealth=self.wealth,\n",
    "                p=self.p, beta=self.beta, alpha=self.alpha,\n",
    "                reward_rb=self.reward_rb, cost_rb=self.cost_rb)\n",
    "        else:\n",
    "            sv_rb = SV_rule_break(\n",
    "                reward_rb=self.reward_rb, cost_rb=self.cost_rb, wealth=self.wealth,\n",
    "                p=self.p, gamma=self.gamma, beta=self.beta, alpha=self.alpha)\n",
    "        sv_rf = SV_follow_rules(self.reward_rf, self.wealth, self.gamma)\n",
    "        p_rb = bounded_softmax(sv_rb, sv_rf)\n",
    "        self.decision = int(bernoulli.rvs(p_rb))\n",
    "\n",
    "    def step(self):\n",
    "        self.relative_desperation()\n",
    "        self.compute_decision()\n",
    "        if self.decision == 1:\n",
    "            if bernoulli.rvs(self.p):\n",
    "                self.caught = False\n",
    "                self.wealth += self.reward_rb\n",
    "            else:\n",
    "                self.caught = True\n",
    "                self.wealth -= self.cost_rb\n",
    "        else:\n",
    "            self.wealth += self.reward_rf\n",
    "        living_cost = np.clip(np.random.normal(0.8, 0.1), 0.1, 1) * self.reward_rf\n",
    "        self.wealth -= living_cost\n",
    "\n",
    "# ── Model ─────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def gini(model):\n",
    "    \"\"\"Gini coefficient robust to negative wealth (Chen 1982).\"\"\"\n",
    "    w = np.array([a.wealth for a in model.agents])\n",
    "    n = len(w)\n",
    "    if n == 0: return 0\n",
    "    w_sorted = np.sort(w)\n",
    "    idx = np.arange(1, n + 1)\n",
    "    numerator = 2 * np.sum((2 * idx - n - 1) * w_sorted)\n",
    "    denominator = n * np.sum(np.abs(w))\n",
    "    return numerator / denominator if denominator != 0 else 0\n",
    "\n",
    "def crime_rate(model):\n",
    "    return np.mean([a.decision for a in model.agents])\n",
    "\n",
    "def avg_wealth(model):\n",
    "    return np.mean([a.wealth for a in model.agents])\n",
    "\n",
    "class DMAPModel(Model):\n",
    "    def __init__(self, width=20, height=20, lambd=0.2, gamma=0.3,\n",
    "                 reward_rb=50, reward_rf=25, cost_rb=250,\n",
    "                 beta_loc=1, beta_scale=0.5, alpha_loc=1, alpha_scale=0.5,\n",
    "                 min_start_wealth=100, p=0.8,\n",
    "                 num_neighbors=5, income_rank_threshold=0.05, seed=None):\n",
    "        super().__init__(seed=seed)\n",
    "        self.width = width\n",
    "        self.height = height\n",
    "        self.grid = SingleGrid(width, height, torus=True)\n",
    "\n",
    "        for _, pos in self.grid.coord_iter():\n",
    "            agent = Individual(\n",
    "                model=self, lambd=lambd, gamma=gamma,\n",
    "                reward_rb=reward_rb, reward_rf=reward_rf, cost_rb=cost_rb,\n",
    "                min_start_wealth=min_start_wealth, p=p,\n",
    "                beta_loc=beta_loc, beta_scale=beta_scale,\n",
    "                alpha_loc=alpha_loc, alpha_scale=alpha_scale,\n",
    "                num_neighbors=num_neighbors,\n",
    "                income_rank_threshold=income_rank_threshold)\n",
    "            self.grid.place_agent(agent, pos)\n",
    "\n",
    "        self.datacollector = DataCollector(\n",
    "            model_reporters={\n",
    "                \"Gini\": gini,\n",
    "                \"Crime Rate\": crime_rate,\n",
    "                \"Avg Wealth\": avg_wealth,\n",
    "            },\n",
    "            agent_reporters={\n",
    "                \"Wealth\": \"wealth\",\n",
    "                \"Decision\": \"decision\",\n",
    "                \"Rank\": \"income_rank\",\n",
    "                \"Desperate\": \"desperate_state\",\n",
    "            }\n",
    "        )\n",
    "        self.datacollector.collect(self)\n",
    "\n",
    "    def step(self):\n",
    "        self.agents.shuffle_do(\"step\")\n",
    "        self.datacollector.collect(self)\n",
    "\n",
    "print(\"✓ Model defined\")"
   ],
   "id": "model-code"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Run a single simulation\n",
    "\n",
    "**Demo parameters:** 20×20 grid (400 agents), 25 steps.  \n",
    "The full model uses a 100×100 grid (10,000 agents) and runs 100 replications × 45 parameter conditions on a computing cluster."
   ],
   "id": "run-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "GRID_SIZE = 20   # full model uses 100\n",
    "N_STEPS   = 25\n",
    "SEED      = 42\n",
    "\n",
    "model = DMAPModel(\n",
    "    width=GRID_SIZE, height=GRID_SIZE,\n",
    "    lambd=0.2,                   # desperation severity\n",
    "    gamma=0.3,                   # risk aversion\n",
    "    beta_loc=1, alpha_loc=1,     # risk-neutral baseline\n",
    "    income_rank_threshold=0.05,  # bottom 5% = desperate\n",
    "    num_neighbors=5,\n",
    "    seed=SEED\n",
    ")\n",
    "\n",
    "for _ in range(N_STEPS):\n",
    "    model.step()\n",
    "\n",
    "model_df = model.datacollector.get_model_vars_dataframe()\n",
    "agent_df = model.datacollector.get_agent_vars_dataframe()\n",
    "\n",
    "print(f\"Steps: {len(model_df)}\")\n",
    "print(f\"Agents × steps: {len(agent_df):,}\")\n",
    "model_df.tail()"
   ],
   "id": "run-single"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Visualize model-level outcomes over time"
   ],
   "id": "viz-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 3, figsize=(14, 4))\n",
    "fig.suptitle(\"DMAP Model — Single Run (20×20 grid, 25 steps)\", fontsize=13, y=1.02)\n",
    "\n",
    "titles   = [\"Gini Coefficient\", \"Crime Rate\", \"Average Wealth\"]\n",
    "cols     = [\"Gini\", \"Crime Rate\", \"Avg Wealth\"]\n",
    "colors   = [\"#c0392b\", \"#8e44ad\", \"#2980b9\"]\n",
    "ylabels  = [\"Gini\", \"Proportion breaking rules\", \"Mean wealth\"]\n",
    "\n",
    "for ax, title, col, color, ylabel in zip(axes, titles, cols, colors, ylabels):\n",
    "    ax.plot(model_df.index, model_df[col], color=color, linewidth=2)\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(\"Step\")\n",
    "    ax.set_ylabel(ylabel)\n",
    "    ax.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "viz-model"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Wealth distribution at final step"
   ],
   "id": "wealth-dist-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "final_step = agent_df.xs(N_STEPS, level=\"Step\")\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "# Wealth histogram by rule-breaking decision\n",
    "for decision, label, color in [(0, \"Rule-followers\", \"#2980b9\"), (1, \"Rule-breakers\", \"#c0392b\")]:\n",
    "    subset = final_step[final_step[\"Decision\"] == decision][\"Wealth\"]\n",
    "    axes[0].hist(subset, bins=30, alpha=0.6, label=f\"{label} (n={len(subset)})\", color=color)\n",
    "axes[0].set_title(\"Wealth distribution at final step\")\n",
    "axes[0].set_xlabel(\"Wealth\")\n",
    "axes[0].set_ylabel(\"Count\")\n",
    "axes[0].legend()\n",
    "axes[0].grid(alpha=0.3)\n",
    "\n",
    "# Wealth by desperation state\n",
    "for state, label, color in [(0, \"Not desperate\", \"#27ae60\"), (1, \"Desperate\", \"#e67e22\")]:\n",
    "    subset = final_step[final_step[\"Desperate\"] == state][\"Wealth\"]\n",
    "    axes[1].hist(subset, bins=30, alpha=0.6, label=f\"{label} (n={len(subset)})\", color=color)\n",
    "axes[1].set_title(\"Wealth distribution by desperation state\")\n",
    "axes[1].set_xlabel(\"Wealth\")\n",
    "axes[1].set_ylabel(\"Count\")\n",
    "axes[1].legend()\n",
    "axes[1].grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nFinal step summary:\")\n",
    "print(final_step[[\"Wealth\", \"Decision\", \"Desperate\"]].describe().round(2))"
   ],
   "id": "wealth-dist"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Spatial heatmap — wealth and rule-breaking on the grid\n",
    "\n",
    "Visualizes the spatial distribution of wealth and rule-breaking behavior at the final step."
   ],
   "id": "spatial-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Reconstruct final grid state from agent positions\n",
    "wealth_grid   = np.zeros((GRID_SIZE, GRID_SIZE))\n",
    "decision_grid = np.zeros((GRID_SIZE, GRID_SIZE))\n",
    "\n",
    "for agent in model.agents:\n",
    "    x, y = agent.pos\n",
    "    wealth_grid[y, x]   = agent.wealth\n",
    "    decision_grid[y, x] = agent.decision\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "fig.suptitle(\"Spatial distribution at final step\", fontsize=13)\n",
    "\n",
    "im0 = axes[0].imshow(wealth_grid, cmap=\"RdYlGn\", origin=\"lower\")\n",
    "plt.colorbar(im0, ax=axes[0], label=\"Wealth\")\n",
    "axes[0].set_title(\"Wealth heatmap\")\n",
    "axes[0].set_xlabel(\"Grid X\")\n",
    "axes[0].set_ylabel(\"Grid Y\")\n",
    "\n",
    "im1 = axes[1].imshow(decision_grid, cmap=\"RdBu_r\", vmin=0, vmax=1, origin=\"lower\")\n",
    "plt.colorbar(im1, ax=axes[1], label=\"0 = follow rules / 1 = break rules\")\n",
    "axes[1].set_title(\"Rule-breaking heatmap\")\n",
    "axes[1].set_xlabel(\"Grid X\")\n",
    "axes[1].set_ylabel(\"Grid Y\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "spatial-viz"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Parameter sweep — effect of desperation severity (λ)\n",
    "\n",
    "Runs 5 short simulations across different `lambd` values to show how desperation severity affects crime rates and inequality."
   ],
   "id": "sweep-header"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lambd_values = [0.0, 0.1, 0.2, 0.5, 1.0]\n",
    "results = []\n",
    "\n",
    "for lv in lambd_values:\n",
    "    m = DMAPModel(width=GRID_SIZE, height=GRID_SIZE, lambd=lv, seed=SEED)\n",
    "    for _ in range(N_STEPS):\n",
    "        m.step()\n",
    "    df = m.datacollector.get_model_vars_dataframe()\n",
    "    df[\"lambd\"] = lv\n",
    "    results.append(df)\n",
    "    print(f\"  λ={lv:.1f} → final crime rate: {df['Crime Rate'].iloc[-1]:.3f}, Gini: {df['Gini'].iloc[-1]:.3f}\")\n",
    "\n",
    "sweep_df = pd.concat(results)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n",
    "fig.suptitle(\"Parameter sweep: desperation severity (λ)\", fontsize=13)\n",
    "\n",
    "palette = sns.color_palette(\"coolwarm\", len(lambd_values))\n",
    "\n",
    "for i, lv in enumerate(lambd_values):\n",
    "    sub = sweep_df[sweep_df[\"lambd\"] == lv]\n",
    "    axes[0].plot(sub.index, sub[\"Crime Rate\"], label=f\"λ={lv}\", color=palette[i], linewidth=2)\n",
    "    axes[1].plot(sub.index, sub[\"Gini\"],       label=f\"λ={lv}\", color=palette[i], linewidth=2)\n",
    "\n",
    "for ax, title, ylabel in zip(axes,\n",
    "                               [\"Crime Rate over time\", \"Gini Coefficient over time\"],\n",
    "                               [\"Proportion breaking rules\", \"Gini\"]):\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(\"Step\")\n",
    "    ax.set_ylabel(ylabel)\n",
    "    ax.legend(title=\"λ\")\n",
    "    ax.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "id": "sweep"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Next steps\n",
    "\n",
    "This demo runs on a 20×20 grid with a single replication. The full model uses:\n",
    "- **100×100 grid** (10,000 agents)\n",
    "- **100 replications** per condition\n",
    "- **45 parameter conditions** (3 × β values × 3 × α values × 5 × desperation thresholds)\n",
    "- Run as **SLURM array jobs** on the Yale Milgram computing cluster\n",
    "\n",
    "**Key parameters to explore:**\n",
    "\n",
    "| Parameter | What it controls | Values in full study |\n",
    "|-----------|-----------------|----------------------|\n",
    "| `beta_loc` (β) | Uncertainty aversion — how agents distort perceived probabilities | -1, 0, 1 |\n",
    "| `alpha_loc` (α) | Probability sensitivity — curvature of Prelec weighting | 0.5, 1, 2 |\n",
    "| `income_rank_threshold` | What fraction of agents become \"desperate\" | 0.05–0.65 |\n",
    "| `lambd` (λ) | How much desperation amplifies rule-breaking utility | 0.2 (fixed) |\n",
    "\n",
    "**Full repo:** [github.com/blam3/ABM-poverty-uncertainty](https://github.com/blam3/ABM-poverty-uncertainty)"
   ],
   "id": "next-steps"
  }
 ]
}"
